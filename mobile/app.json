{
  "expo": {
    "name": "BodyTrack",
    "slug": "bodytrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bodytrack",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bodytrack.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O BodyTrack precisa da câmera para ler QR Codes dos relatórios de análise corporal."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1A2E"
      },
      "package": "com.bodytrack.app",
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para leitura de QR Code"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "extraMavenRepos": [
              "https://jitpack.io",
              "https://repo1.maven.org/maven2"
            ]
          }
        }
      ],
      "./plugins/withAndroidCleartextTraffic.js",
      "./plugins/withAndroidLocalBuild.js",
      "expo-asset"
    ],
    "extra": {
      "storageMode": "local",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "25353c1b-3f31-4ba0-91c0-68e3435da77c"
      }
    },
    "owner": "dkillers"
  }
}
